# ─────────────────────────────────────────────────────────────
# Analytics DB — the EXISTING MySQL being queried. READ-ONLY.
# Point this at a read-only replica with a SELECT-only account.
# ─────────────────────────────────────────────────────────────
ANALYTICS_DB_HOST=
ANALYTICS_DB_PORT=3306
ANALYTICS_DB_USER=
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_DATABASE=
# Which schema(s) to include in the catalog/retrieval (comma-separated). The
# analytics account may see multiple databases — pick which to expose. Generated
# SQL uses schema-qualified names (db.table) so you can mix schemas. Empty =
# just ANALYTICS_DB_DATABASE.  Override per-bootstrap with: -- --schemas=db1,db2
ANALYTICS_SCHEMAS=

# ─────────────────────────────────────────────────────────────
# LLM provider for the text-to-SQL engine: claude | gemini | groq | ollama | openai-compat.
# The engine talks to a provider interface, so switching is just this var
# plus the matching API key below. (groq/ollama are free options.)
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=claude

# Claude — get a key at console.anthropic.com.
# Model defaults to claude-sonnet-4-6; bump to claude-opus-4-8 for hard questions.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (Google AI Studio free tier) — get a key at aistudio.google.com/apikey.
# NOTE: free tier is tiny (gemini-2.5-flash ~20 req/day). Model defaults to gemini-2.5-flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (free cloud) — LLM_PROVIDER=groq. Free key at console.groq.com/keys.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local, free/unlimited) — LLM_PROVIDER=ollama. Run Ollama + pull a model:
#   ollama pull qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# Generic OpenAI-compatible endpoint — LLM_PROVIDER=openai-compat (OpenRouter, etc.)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# ─────────────────────────────────────────────────────────────
# Auth (slice 05). Generate a secret with: npx auth secret  (or: openssl rand -base64 33)
# ─────────────────────────────────────────────────────────────
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────
# Guardrails (PRD §4). All optional — sensible defaults shown.
# ─────────────────────────────────────────────────────────────
GUARDRAIL_MAX_ROWS=1000
GUARDRAIL_STATEMENT_TIMEOUT_MS=5000
# Comma-separated. Any query referencing a blocked table is rejected.
GUARDRAIL_BLOCKED_TABLES=
# Comma-separated. Rejected if named in the query OR surfaced in results.
# Defaults to a PII/secret set (password, token, ssn, credit_card, ...).
GUARDRAIL_BLOCKED_COLUMNS=

# ─────────────────────────────────────────────────────────────
# State DB — the app's OWN MySQL. READ-WRITE.
# A separate instance/account from the analytics DB. Stores
# conversations, dashboards, saved queries, table catalog.
# ─────────────────────────────────────────────────────────────
STATE_DB_HOST=
STATE_DB_PORT=3306
STATE_DB_USER=
STATE_DB_PASSWORD=
STATE_DB_DATABASE=
